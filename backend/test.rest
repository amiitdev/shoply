@baseUrl = http://localhost:5000
@productUrl = {{baseUrl}}/api/products

############################################################
### 🔐 AUTH (COOKIE BASED)
############################################################

### 📝 Register
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "name": "Amit",
  "email": "amit@test.com",
  "password": "123456"
}

###
### 🔑 Login → copy token from Set-Cookie
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "amit@test.com",
  "password": "123456"
}

###
### 👤 Get Profile
GET {{baseUrl}}/api/auth/user
Cookie: token=YOUR_TOKEN

###
### 👑 Get All Users (Admin)
GET {{baseUrl}}/api/auth/admin
Cookie: token=YOUR_TOKEN

############################################################
### 🧪 SERVER CHECK
############################################################

###
GET {{baseUrl}}

############################################################
### 📦 PRODUCTS (READ)
############################################################

###
### 📥 Get All Products
GET {{productUrl}}

###
### 🔍 Get Product By ID
# 👉 replace with real Mongo ID
GET {{productUrl}}/69d29d7648aaefe79979f46c

############################################################
### ➕ CREATE PRODUCT (RAW MULTIPART 🔥)
############################################################
# ✅ Uses manual multipart (stable for .rest)
# ✅ Boundary must match everywhere
# ⚠️ Keep exact format (no extra spaces)

###
POST {{productUrl}}
Cookie: token=YOUR_TOKEN
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="name"

Test Product
--boundary
Content-Disposition: form-data; name="price"

100
--boundary
Content-Disposition: form-data; name="description"

Nice product
--boundary
Content-Disposition: form-data; name="category"

Electronics
--boundary
Content-Disposition: form-data; name="stock"

10
--boundary
Content-Disposition: form-data; name="image"; filename="hero.png"
Content-Type: image/png

< /home/amit/Downloads/hero.png
--boundary--

############################################################
### ✏️ UPDATE PRODUCT
############################################################
# ⚠️ Same multipart structure required if sending image

###
PUT {{productUrl}}/YOUR_PRODUCT_ID
Cookie: token=YOUR_TOKEN
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="name"

Updated Product
--boundary
Content-Disposition: form-data; name="price"

200
--boundary
Content-Disposition: form-data; name="description"

Updated desc
--boundary
Content-Disposition: form-data; name="category"

Updated category
--boundary
Content-Disposition: form-data; name="stock"

5
--boundary
Content-Disposition: form-data; name="image"; filename="hero.png"
Content-Type: image/png

< /home/amit/Downloads/hero.png
--boundary--

############################################################
### ❌ DELETE PRODUCT
############################################################

###
DELETE {{productUrl}}/69d29e7548aaefe79979f46e
Cookie: token=YOUR_TOKEN